@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJtaXJhbmRhQHllc3Nlcm0uZGV2IiwiaWF0IjoxNzgzNTUwNDgxLCJleHAiOjE3ODM1NTEzODF9.NlrPPLlI2JLWFTfll_zswwuNek6zOZCj4CGfTIreBt4
@adminAccessToken = V2h5VGhpcklzVGhpcklzVGhpcklzVGhpcklzVGhpcklzVGhpcklzVGhpcklz

### Change password
POST {{baseUrl}}/api/v1/users/change-password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "currentPassword": "password123",
  "newPassword": "password456"
}

### Update profile
PUT {{baseUrl}}/api/v1/users/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Demo User",
  "email": "demo@example.com",
  "phone": "+50588887777",
  "avatar": "https://example.com/avatar.png"
}

### List users
GET {{baseUrl}}/api/v1/users?name=demo&email=example&role=USER&active=true&page=0&size=20&sort=createdAt,desc
Authorization: Bearer {{accessToken}}
Accept: application/json

### Search users
POST {{baseUrl}}/api/v1/users/search?page=0&size=20&sort=createdAt,desc
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "demo",
  "email": "example",
  "roles": ["USER"],
  "active": true,
  "createdFrom": "2026-01-01T00:00:00Z",
  "createdTo": "2026-12-31T23:59:59Z"
}

### Deactivate user
DELETE {{baseUrl}}/api/v1/users/1
Authorization: Bearer {{adminAccessToken}}

### Change role
POST {{baseUrl}}/api/v1/admin/users/1/role
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "role": "ADMIN"
}

### Change role forbidden for normal user
POST {{baseUrl}}/api/v1/admin/users/1/role
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "role": "ADMIN"
}
