### Register
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "name": "Yesser Miranda",
  "email": "miranda@yesserm.dev",
  "password": "password1234"
}

### Register admin with internal setup key
POST {{baseUrl}}/api/v1/auth/register-admin
X-Admin-Setup-Key: {{adminSetupKey}}
Content-Type: application/json

{
  "name": "Admin User",
  "email": "admin2@example.com",
  "password": "Admin1234!"
}

### Login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "miranda@yesserm.dev",
  "password": "password1234"
}

### Refresh access token
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Get profile
GET {{baseUrl}}/api/v1/users/me
Authorization: Bearer {{accessToken}}
Accept: application/json

### Audit check: update profile, then inspect updatedBy in response
PUT {{baseUrl}}/api/v1/users/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Yesser Miranda",
  "email": "miranda@yesserm.dev",
  "phone": "+50588887777",
  "avatar": "https://example.com/avatar.png"
}

### Get all users
GET {{baseUrl}}/api/v1/users
Authorization: Bearer {{accessToken}}
Accept: application/json
